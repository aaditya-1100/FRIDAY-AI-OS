{
  "name": "friday-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "start": "cross-env NODE_ENV=development electron .",
    "dev:all": "concurrently -k \"npm run dev\" \"npm run start\"",
    "build": "npx tsc && npx vite build",
    "preview": "vite preview",
    "build:electron": "npm run build && npx electron-packager . FRIDAY --platform=win32 --arch=x64 --out=dist-electron --overwrite --ignore=node_modules --ignore=src --ignore=public --ignore=.vite --ignore=tailwind.config.js --ignore=postcss.config.js --ignore=vite.config.ts --ignore=tsconfig.json --ignore=package-lock.json --ignore=.gitignore --ignore=\"^/\\.\" "
  },
  "build": {
    "appId": "com.friday.assistant",
    "productName": "FRIDAY"
  },
  "dependencies": {
    "@react-three/fiber": "^8.17.10",
    "framer-motion": "^11.11.17",
    "jotai": "^2.10.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^9.0.10"
  }
}

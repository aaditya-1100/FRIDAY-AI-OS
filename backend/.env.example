# Groq LLM Key (Required)
GROQ_API_KEY=

# Tavily Search API Key (Required for web search)
TAVILY_API_KEY=

# Spotify Integration Credentials (Optional)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# Redis Session Configuration (Optional, defaults to SQLite fallback)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# Per-user data isolation (Optional)
# Set to a user-specific subdirectory to keep each user's data separate.
# Default: backend/data/ (relative to the backend directory)
# Example: FRIDAY_DATA_DIR=backend/data/alice
FRIDAY_DATA_DIR=
